
@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 0 0% 100%;
    --foreground: 158 30% 8%;
    --card: 0 0% 100%;
    --card-foreground: 158 30% 8%;
    --popover: 0 0% 100%;
    --popover-foreground: 158 30% 8%;
    --primary: 158 84% 28%;
    --primary-foreground: 0 0% 98%;
    --secondary: 152 60% 95%;
    --secondary-foreground: 158 64% 15%;
    --muted: 152 20% 95%;
    --muted-foreground: 158 10% 46%;
    --accent: 152 60% 94%;
    --accent-foreground: 158 64% 15%;
    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 0 0% 98%;
    --border: 152 20% 88%;
    --input: 152 20% 88%;
    --ring: 158 84% 28%;
    --radius: 0.5rem;
  }

  .dark {
    --background: 0 0% 0%;
    --foreground: 0 0% 98%;
    --card: 0 0% 4%;
    --card-foreground: 0 0% 98%;
    --popover: 0 0% 4%;
    --popover-foreground: 0 0% 98%;
    --primary: 142 76% 45%;
    --primary-foreground: 0 0% 0%;
    --secondary: 0 0% 8%;
    --secondary-foreground: 0 0% 98%;
    --muted: 0 0% 8%;
    --muted-foreground: 0 0% 55%;
    --accent: 0 0% 10%;
    --accent-foreground: 0 0% 98%;
    --destructive: 0 62.8% 40%;
    --destructive-foreground: 0 0% 98%;
    --border: 0 0% 12%;
    --input: 0 0% 8%;
    --ring: 142 76% 45%;
  }
}

@layer base {
  * { @apply border-border; }
  body { @apply bg-background text-foreground; }
}

/* SPACE BLACK BACKGROUND — fixed, covers everything */
.dark,
.dark body {
  color: #f9fafb !important;
  background-color: #000000 !important;
  background-image:
    radial-gradient(ellipse 90% 70% at 15% 15%, rgba(0, 80, 40, 0.5) 0%, transparent 55%),
    radial-gradient(ellipse 70% 60% at 85% 85%, rgba(0, 60, 30, 0.4) 0%, transparent 50%),
    radial-gradient(ellipse 50% 40% at 50% 50%, rgba(0, 40, 20, 0.2) 0%, transparent 60%) !important;
  background-size: 100% 100%, 100% 100%, 100% 100% !important;
  background-attachment: fixed !important;
}

/* Kill ALL light backgrounds — let space show */
.dark .min-h-screen,
.dark [class*="from-emerald-50"],
.dark [class*="via-green-50"],
.dark [class*="to-teal-50"],
.dark [class*="from-green-50"],
.dark [class*="bg-gradient-to-br"],
.dark [class*="bg-gradient-to-r"] {
  background: transparent !important;
}

/* LIQUID GLASS CARDS — Apple liquid glass */
.dark .card,
.dark [class*="backdrop-blur"],
.dark [class*="bg-white\/80"],
.dark [class*="bg-white\/70"],
.dark [class*="bg-white\/95"],
.dark [class*="bg-gray-900\/80"],
.dark [class*="bg-gray-900\/70"] {
  background: linear-gradient(
    135deg,
    rgba(0, 255, 100, 0.06) 0%,
    rgba(0, 180, 80, 0.03) 40%,
    rgba(0, 0, 0, 0.4) 100%
  ) !important;
  backdrop-filter: blur(40px) saturate(180%) brightness(1.1) !important;
  -webkit-backdrop-filter: blur(40px) saturate(180%) brightness(1.1) !important;
  border: 1px solid rgba(34, 197, 94, 0.25) !important;
  box-shadow:
    0 0 0 0.5px rgba(34, 197, 94, 0.1),
    0 8px 32px rgba(0, 0, 0, 0.6),
    0 2px 8px rgba(0, 0, 0, 0.4),
    inset 0 1px 0 rgba(255, 255, 255, 0.08),
    inset 0 -1px 0 rgba(0, 0, 0, 0.2) !important;
}

/* HEADER — liquid glass navbar */
.dark header {
  background: linear-gradient(
    180deg,
    rgba(0, 30, 15, 0.7) 0%,
    rgba(0, 0, 0, 0.5) 100%
  ) !important;
  backdrop-filter: blur(40px) saturate(200%) !important;
  -webkit-backdrop-filter: blur(40px) saturate(200%) !important;
  border-bottom: 1px solid rgba(34, 197, 94, 0.15) !important;
  box-shadow:
    0 1px 0 rgba(34, 197, 94, 0.1),
    0 4px 24px rgba(0, 0, 0, 0.3) !important;
}

/* DROPDOWNS — deeper liquid glass */
.dark [class*="rounded-2xl"][class*="shadow-xl"],
.dark [class*="bg-white\/95"] {
  background: linear-gradient(
    145deg,
    rgba(0, 200, 80, 0.08) 0%,
    rgba(0, 0, 0, 0.7) 60%
  ) !important;
  backdrop-filter: blur(60px) saturate(200%) !important;
  -webkit-backdrop-filter: blur(60px) saturate(200%) !important;
  border: 1px solid rgba(34, 197, 94, 0.3) !important;
  box-shadow:
    0 0 0 0.5px rgba(34, 197, 94, 0.15),
    0 0 40px rgba(34, 197, 94, 0.08),
    0 20px 60px rgba(0, 0, 0, 0.8),
    inset 0 1px 0 rgba(255, 255, 255, 0.06) !important;
}

/* SURFACES */
.dark [class*="bg-gray-50"] {
  background: rgba(0, 255, 100, 0.02) !important;
}
.dark [class*="bg-gray-100"] {
  background: rgba(0, 255, 100, 0.04) !important;
}
.dark [class*="bg-gray-800"],
.dark [class*="bg-gray-900"] {
  background: rgba(0, 0, 0, 0.5) !important;
}

/* TEXT */
.dark [class*="text-gray-900"],
.dark h1, .dark h2, .dark h3, .dark h4, .dark h5 {
  color: #ffffff !important;
}
.dark [class*="text-gray-700"] { color: #e5e7eb !important; }
.dark [class*="text-gray-600"] { color: #d1d5db !important; }
.dark [class*="text-gray-500"] { color: #6b7280 !important; }
.dark [class*="text-gray-400"] { color: #4b5563 !important; }

/* BORDERS — green tint */
.dark [class*="border-gray-200"],
.dark [class*="border-white\/20"],
.dark [class*="border-gray-100"],
.dark [class*="border-gray-700"],
.dark [class*="border-gray-800"] {
  border-color: rgba(34, 197, 94, 0.12) !important;
}
.dark [class*="border-b"] { border-color: rgba(34, 197, 94, 0.08) !important; }
.dark [class*="border-t"] { border-color: rgba(34, 197, 94, 0.08) !important; }

/* INPUTS — liquid glass */
.dark input,
.dark textarea,
.dark select {
  background: linear-gradient(135deg, rgba(0,255,100,0.04), rgba(0,0,0,0.3)) !important;
  border: 1px solid rgba(34, 197, 94, 0.2) !important;
  color: #f9fafb !important;
  backdrop-filter: blur(20px) !important;
  -webkit-backdrop-filter: blur(20px) !important;
}
.dark input::placeholder,
.dark textarea::placeholder { color: #374151 !important; }
.dark input:focus,
.dark textarea:focus {
  border-color: #22c55e !important;
  box-shadow:
    0 0 0 2px rgba(34, 197, 94, 0.2),
    0 0 20px rgba(34, 197, 94, 0.15),
    inset 0 1px 0 rgba(255,255,255,0.05) !important;
  outline: none !important;
}

/* BUTTONS — neon green, glowing */
.dark button[class*="from-emerald"],
.dark [class*="bg-gradient"][class*="emerald"],
.dark [class*="from-emerald-700"] {
  background: linear-gradient(135deg, #16a34a, #22c55e) !important;
  box-shadow:
    0 0 20px rgba(34, 197, 94, 0.5),
    0 0 40px rgba(34, 197, 94, 0.2),
    0 4px 15px rgba(0,0,0,0.4) !important;
  color: #000000 !important;
}

/* Submit assignment card — deep liquid green */
.dark [class*="from-emerald-700"][class*="to-emerald-500"] {
  background: linear-gradient(
    135deg,
    rgba(6, 78, 59, 0.7) 0%,
    rgba(5, 150, 105, 0.5) 100%
  ) !important;
  backdrop-filter: blur(30px) saturate(150%) !important;
  -webkit-backdrop-filter: blur(30px) saturate(150%) !important;
  border: 1px solid rgba(34, 197, 94, 0.35) !important;
  box-shadow:
    0 0 50px rgba(5, 150, 105, 0.2),
    0 0 0 0.5px rgba(34,197,94,0.2),
    0 8px 32px rgba(0,0,0,0.5),
    inset 0 1px 0 rgba(255,255,255,0.1) !important;
}

/* ICON BACKGROUNDS */
.dark [class*="bg-emerald-100"] {
  background: rgba(34, 197, 94, 0.12) !important;
  border: 1px solid rgba(34, 197, 94, 0.2) !important;
  box-shadow: 0 0 12px rgba(34,197,94,0.1) !important;
}
.dark [class*="bg-yellow-100"] { background: rgba(234, 179, 8, 0.1) !important; }
.dark [class*="bg-green-100"],
.dark [class*="bg-blue-100"] { background: rgba(34, 197, 94, 0.08) !important; }

/* EMERALD TEXT */
.dark [class*="text-emerald-700"],
.dark [class*="text-emerald-600"] { color: #22c55e !important; }
.dark [class*="text-emerald-400"],
.dark [class*="text-emerald-500"] { color: #4ade80 !important; }

/* AVATAR */
.dark .rounded-full[class*="from-emerald"] {
  box-shadow:
    0 0 20px rgba(34, 197, 94, 0.6),
    0 0 40px rgba(34, 197, 94, 0.2) !important;
}

/* GHOST BUTTONS */
.dark button[class*="ghost"],
.dark [class*="variant-ghost"] { color: #e5e7eb !important; }
.dark button[class*="ghost"]:hover {
  background: rgba(34, 197, 94, 0.06) !important;
}

/* TOGGLES */
.dark [class*="bg-emerald-500"] {
  background: linear-gradient(135deg, #16a34a, #22c55e) !important;
  box-shadow: 0 0 12px rgba(34, 197, 94, 0.6) !important;
}

/* TABLES */
.dark tr:hover { background: rgba(34, 197, 94, 0.04) !important; }
.dark td, .dark th {
  border-color: rgba(34, 197, 94, 0.06) !important;
  color: #e5e7eb !important;
}

/* BADGES */
.dark [class*="bg-gray-200"] {
  background: rgba(255,255,255,0.06) !important;
  color: #9ca3af !important;
}

/* SCROLLBAR */
.dark ::-webkit-scrollbar { width: 6px; }
.dark ::-webkit-scrollbar-track { background: transparent; }
.dark ::-webkit-scrollbar-thumb {
  background: rgba(34,197,94,0.3);
  border-radius: 3px;
}
.dark ::-webkit-scrollbar-thumb:hover { background: rgba(34,197,94,0.6); }

::-webkit-scrollbar { width: 8px; height: 8px; }
::-webkit-scrollbar-track { background: rgba(0,0,0,0.05); border-radius: 4px; }
::-webkit-scrollbar-thumb { background: rgba(5,150,105,0.3); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: rgba(5,150,105,0.5); }

/* HELP WIDGET PULSE */
@keyframes neon-pulse {
  0%, 100% {
    box-shadow: 0 0 10px rgba(34,197,94,0.7), 0 0 20px rgba(34,197,94,0.4);
  }
  50% {
    box-shadow: 0 0 25px rgba(34,197,94,1), 0 0 50px rgba(34,197,94,0.7), 0 0 80px rgba(34,197,94,0.3);
  }
}
.neon-pulse { animation: neon-pulse 2s ease-in-out infinite; }
